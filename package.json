{
  "name": "@telton/connect-svelte-query",
  "version": "0.0.4",
  "description": "Svelte 5 adapter for integrating ConnectRPC with TanStack Query",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm format && pnpm typecheck && pnpm test",
    "publint": "publint --strict",
    "attw": "attw --pack . --ignore-rules cjs-resolves-to-esm",
    "validate": "pnpm publint && pnpm attw",
    "size": "size-limit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && pnpm validate && changeset publish",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "keywords": [
    "svelte",
    "sveltekit",
    "connectrpc",
    "grpc",
    "tanstack-query",
    "protobuf"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/telton/connect-svelte-query.git"
  },
  "homepage": "https://github.com/telton/connect-svelte-query#readme",
  "bugs": {
    "url": "https://github.com/telton/connect-svelte-query/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "peerDependencies": {
    "@connectrpc/connect": "^2",
    "@tanstack/svelte-query": "^6",
    "svelte": "^5"
  },
  "dependencies": {
    "@connectrpc/connect-query-core": "^2.2.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.7",
    "@bufbuild/protobuf": "^2.11.0",
    "@changesets/cli": "^2.30.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tanstack/svelte-query": "^6.1.0",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@vitest/ui": "^4.1.0",
    "happy-dom": "^20.8.4",
    "lint-staged": "^16.4.0",
    "publint": "^0.3.18",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.0.1",
    "svelte": "^5.53.12",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
